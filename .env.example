# Copy to .env on the server and fill in real values. Never commit .env.

# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-a-long-random-string

# Production should be False. Default is False.
DEBUG=False

# Comma-separated. Include every hostname the site answers on.
ALLOWED_HOSTS=ashrafstudio.example.com,www.ashrafstudio.example.com

# Required for HTTPS form submissions in modern Django (5+).
CSRF_TRUSTED_ORIGINS=https://ashrafstudio.example.com,https://www.ashrafstudio.example.com

# Database. Default falls back to local SQLite if unset.
# Postgres example:
# DATABASE_URL=postgres://user:password@127.0.0.1:5432/ashraf_studio
# SQLite (relative path inside project):
# DATABASE_URL=sqlite:///db.sqlite3

# HTTPS / HSTS — only relevant when DEBUG=False
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=3600
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Logging
LOG_LEVEL=INFO

# Optional: timezone (defaults to UTC)
TIME_ZONE=UTC
